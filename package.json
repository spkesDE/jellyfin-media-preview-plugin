{
  "name": "jellyfin-media-preview-plugin",
  "private": true,
  "version": "0.2.2.0",
  "description": "TypeScript build for the Jellyfin Media Preview client bundle.",
  "scripts": {
    "typecheck": "tsc --noEmit && vue-tsc --noEmit",
    "bundle": "node scripts/build.mjs",
    "build": "npm run typecheck && npm run bundle",
    "dev": "vite --config vite.config.ts",
    "dev:bundle": "node scripts/build.mjs --watch"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.38",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.5"
  },
  "dependencies": {
    "vue": "^3.5.38"
  }
}
